# ═══════════════════════════════════════════════
#  PetPulse / Mewoo — .gitignore
# ═══════════════════════════════════════════════

# ── Dependencies ─────────────────────────────
node_modules/
jspm_packages/
web_modules/
bower_components/

# ── Environment & Secrets ────────────────────
.env
.env.*
!.env.example

# ── Security Logs (Story 7) ─────────────────
backend/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── DB Scripts with Credentials ─────────────
backend/scripts/create_app_user.sql

# ── Test / Debug Scripts ─────────────────────
backend/scripts/test_*.js
backend/scripts/check_*.js

# ── Build Output ─────────────────────────────
dist/
.dist/
build/
out/
.next/
.nuxt/

# ── OS Files ─────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# ── IDE / Editor ─────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.cursorrules

# ── Coverage & Testing ──────────────────────
coverage/
*.lcov
.nyc_output/
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Runtime / Cache ──────────────────────────
pids/
*.pid
*.pid.lock
*.seed
.cache/
.parcel-cache/
.fusebox/
.dynamodb/
.serverless/
*.tsbuildinfo
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history
*.tgz
.yarn-integrity
.grunt
.lock-wscript
lib-cov/
.tern-port

# ── Vercel ───────────────────────────────────
.vercel/
